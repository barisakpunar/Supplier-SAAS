@{
    ViewBag.PageTitle = T("Admin.StoreOwner.Panel").Text;
    NopHtml.SetActiveMenuItemSystemName("StoreOwnerPanel");
}

<div class="content-header clearfix">
    <h1 class="float-left">@T("Admin.StoreOwner.Panel")</h1>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8">
                <div class="card card-default">
                    <div class="card-header">
                        <h3 class="card-title">@T("Admin.StoreOwner.Panel.Account")</h3>
                    </div>
                    <div class="card-body">
                        <p><strong>@T("Admin.StoreOwner.Panel.Fields.User"):</strong> @ViewBag.StoreOwnerEmail</p>
                        <p><strong>@T("Admin.StoreOwner.Panel.Fields.Store"):</strong> @ViewBag.StoreName</p>
                        <p><strong>@T("Admin.StoreOwner.Panel.Fields.StoreId"):</strong> @ViewBag.StoreId</p>
                        <p class="mb-0">@T("Admin.StoreOwner.Panel.Info")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
