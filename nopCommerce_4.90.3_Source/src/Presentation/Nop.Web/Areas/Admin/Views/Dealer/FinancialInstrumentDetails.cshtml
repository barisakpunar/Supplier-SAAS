@using System.Globalization
@model DealerFinancialInstrumentDetailsModel
@{
    ViewBag.PageTitle = T("Admin.Customers.DealerFinancialInstruments.Details").Text;
    NopHtml.SetActiveMenuItemSystemName("DealerFinancialInstruments");
}

<div class="content-header clearfix">
    <h1 class="float-left">@T("Admin.Customers.DealerFinancialInstruments.Details")</h1>
    <div class="float-right">
        <a asp-action="FinancialInstruments" asp-controller="Dealer" class="btn btn-default">
            <i class="fas fa-arrow-left"></i>
            @T("Admin.Customers.DealerFinancialInstruments.BackToList")
        </a>
        @if (Model.DealerCollectionId.HasValue)
        {
            <a asp-action="CollectionDetails" asp-controller="Dealer" asp-route-id="@Model.DealerCollectionId.Value" class="btn btn-default">
                <i class="fas fa-link"></i>
                @T("Admin.Customers.DealerFinancialInstruments.LinkedCollection.Open")
            </a>
        }
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default">
                    <div class="card-header">
                        <h3 class="card-title">@T("Admin.Customers.DealerFinancialInstruments.Info")</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.Store"):</strong> @Model.StoreName
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.Dealer"):</strong> @Model.DealerName
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.Customer"):</strong> @(string.IsNullOrWhiteSpace(Model.CustomerName) ? "-" : Model.CustomerName)
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.Type"):</strong> @Model.InstrumentType
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.Status"):</strong> @Model.InstrumentStatus
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.Amount"):</strong> @Model.Amount.ToString("0.####", CultureInfo.CurrentCulture)
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.InstrumentNo"):</strong> @(string.IsNullOrWhiteSpace(Model.InstrumentNo) ? "-" : Model.InstrumentNo)
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.IssueDate"):</strong> @(Model.IssueDateUtc.HasValue ? Model.IssueDateUtc.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) : "-")
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.DueDate"):</strong> @(Model.DueDateUtc.HasValue ? Model.DueDateUtc.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) : "-")
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.BankName"):</strong> @(string.IsNullOrWhiteSpace(Model.BankName) ? "-" : Model.BankName)
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.BranchName"):</strong> @(string.IsNullOrWhiteSpace(Model.BranchName) ? "-" : Model.BranchName)
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.AccountNo"):</strong> @(string.IsNullOrWhiteSpace(Model.AccountNo) ? "-" : Model.AccountNo)
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.DrawerName"):</strong> @(string.IsNullOrWhiteSpace(Model.DrawerName) ? "-" : Model.DrawerName)
                            </div>
                            <div class="col-md-12 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.Note"):</strong> @(string.IsNullOrWhiteSpace(Model.Note) ? "-" : Model.Note)
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-header">
                        <h3 class="card-title">@T("Admin.Customers.DealerFinancialInstruments.Actions")</h3>
                    </div>
                    <div class="card-body">
                        <div class="btn-group">
                            @if (Model.CanMarkCollected)
                            {
                                <form asp-action="UpdateFinancialInstrumentStatus" asp-controller="Dealer" method="post" class="mr-2">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="statusId" value="@((int)Nop.Core.Domain.Customers.DealerFinancialInstrumentStatus.Collected)" />
                                    <nop-antiforgery-token />
                                    <button type="submit" class="btn btn-success">@T("Admin.Customers.DealerFinancialInstruments.Actions.MarkCollected")</button>
                                </form>
                            }
                            @if (Model.CanMarkReturned)
                            {
                                <form asp-action="UpdateFinancialInstrumentStatus" asp-controller="Dealer" method="post" class="mr-2">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="statusId" value="@((int)Nop.Core.Domain.Customers.DealerFinancialInstrumentStatus.Returned)" />
                                    <nop-antiforgery-token />
                                    <button type="submit" class="btn btn-warning">@T("Admin.Customers.DealerFinancialInstruments.Actions.MarkReturned")</button>
                                </form>
                            }
                            @if (Model.CanMarkProtested)
                            {
                                <form asp-action="UpdateFinancialInstrumentStatus" asp-controller="Dealer" method="post">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="statusId" value="@((int)Nop.Core.Domain.Customers.DealerFinancialInstrumentStatus.Protested)" />
                                    <nop-antiforgery-token />
                                    <button type="submit" class="btn btn-danger">@T("Admin.Customers.DealerFinancialInstruments.Actions.MarkProtested")</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-header">
                        <h3 class="card-title">@T("Admin.Customers.DealerCollections.Audit")</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerCollections.Fields.CreatedBy"):</strong> @(string.IsNullOrWhiteSpace(Model.CreatedByCustomerName) ? "-" : Model.CreatedByCustomerName)
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerCollections.Fields.CreatedOnUtc"):</strong> @Model.CreatedOnUtc.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerCollections.Fields.UpdatedOnUtc"):</strong> @(Model.UpdatedOnUtc.HasValue ? Model.UpdatedOnUtc.Value.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture) : "-")
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>@T("Admin.Customers.DealerFinancialInstruments.Fields.LinkedCollection"):</strong>
                                @if (Model.DealerCollectionId.HasValue)
                                {
                                    <a asp-action="CollectionDetails" asp-controller="Dealer" asp-route-id="@Model.DealerCollectionId.Value">@string.Format(T("Admin.Customers.DealerCollections.Fields.CollectionLink").Text, Model.DealerCollectionId.Value)</a>
                                }
                                else
                                {
                                    @("-")
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-header">
                        <h3 class="card-title">@T("Admin.Customers.DealerFinanceAudit.Timeline")</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>@T("Admin.Customers.DealerFinanceAudit.Columns.PerformedOn")</th>
                                        <th>@T("Admin.Customers.DealerFinanceAudit.Columns.EntityType")</th>
                                        <th>@T("Admin.Customers.DealerFinanceAudit.Columns.ActionType")</th>
                                        <th>@T("Admin.Customers.DealerFinanceAudit.Columns.StatusTransition")</th>
                                        <th>@T("Admin.Customers.DealerFinanceAudit.Columns.PerformedBy")</th>
                                        <th>@T("Admin.Customers.DealerFinanceAudit.Columns.Note")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.AuditTrail.Any())
                                    {
                                        foreach (var item in Model.AuditTrail)
                                        {
                                            <tr>
                                                <td>@item.PerformedOnUtc.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)</td>
                                                <td>@item.EntityType</td>
                                                <td>@item.ActionType</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.StatusTransition) ? "-" : item.StatusTransition)</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.PerformedByCustomerName) ? "-" : item.PerformedByCustomerName)</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.Note) ? "-" : item.Note)</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center">@T("Admin.Customers.DealerFinanceAudit.NoData")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
