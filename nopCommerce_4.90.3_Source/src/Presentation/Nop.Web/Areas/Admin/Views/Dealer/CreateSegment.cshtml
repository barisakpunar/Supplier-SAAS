@model DealerSegmentModel
@{
    ViewBag.PageTitle = T("Admin.Customers.DealerSegments.AddNew").Text;
    NopHtml.SetActiveMenuItemSystemName("DealerSegments");
}

<form asp-action="CreateSegment" method="post">
    <div class="content-header clearfix">
        <h1 class="float-left">@T("Admin.Customers.DealerSegments.AddNew")</h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-floppy-disk"></i>
                @T("Admin.Common.Save")
            </button>
            <button type="submit" name="save-continue" class="btn btn-primary">
                <i class="far fa-floppy-disk"></i>
                @T("Admin.Common.SaveContinue")
            </button>
        </div>
    </div>
    <partial name="_CreateOrUpdateSegment" model="Model" />
</form>
