@using System.Globalization
@model DealerCollectionListModel
@{
    ViewBag.PageTitle = T("Admin.Customers.DealerCollections").Text;
    NopHtml.SetActiveMenuItemSystemName("DealerCollections");
}

<div class="content-header clearfix">
    <h1 class="float-left">@T("Admin.Customers.DealerCollections")</h1>
    <div class="float-right">
        <a asp-action="CreateCollection" class="btn btn-primary">
            <i class="fas fa-square-plus"></i>
            @T("Admin.Customers.DealerCollections.AddNew")
        </a>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <form asp-action="Collections" asp-controller="Dealer" method="get">
                            <div class="row">
                                @if (!Model.IsStoreOwner)
                                {
                                    <div class="col-md-6">
                                        <div class="form-group row">
                                            <div class="col-md-4">
                                                <nop-label asp-for="SearchStoreId" />
                                            </div>
                                            <div class="col-md-8">
                                                <nop-select asp-for="SearchStoreId" asp-items="Model.AvailableStores" />
                                            </div>
                                        </div>
                                    </div>
                                }
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchDealerId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchDealerId" asp-items="Model.AvailableDealers" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchCollectionMethodId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchCollectionMethodId" asp-items="Model.AvailableCollectionMethods" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchCollectionStatusId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchCollectionStatusId" asp-items="Model.AvailableCollectionStatuses" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchCollectionDateFromUtc" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="SearchCollectionDateFromUtc" asp-template="DateNullable" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchCollectionDateToUtc" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="SearchCollectionDateToUtc" asp-template="DateNullable" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="text-center col-12">
                                    <button type="submit" class="btn btn-primary btn-search">
                                        <i class="fas fa-magnifying-glass"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.CollectionDate")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.Dealer")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.Store")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.Customer")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.Method")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.Status")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.Amount")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.DocumentNo")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.DueDate")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.ReferenceNo")</th>
                                        <th>@T("Admin.Customers.DealerCollections.Columns.Note")</th>
                                        <th style="width: 100px;">@T("Admin.Common.View")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Collections.Any())
                                    {
                                        foreach (var item in Model.Collections)
                                        {
                                            <tr>
                                                <td>@item.CollectionDateUtc.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)</td>
                                                <td>
                                                    @item.DealerName
                                                    <div>
                                                        <a asp-action="Edit" asp-controller="Dealer" asp-route-id="@item.DealerId">@T("Admin.Customers.Dealers.Transactions.OpenDealer")</a>
                                                    </div>
                                                </td>
                                                <td>@item.StoreName</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.CustomerName) ? "-" : item.CustomerName)</td>
                                                <td>@item.CollectionMethod</td>
                                                <td>@item.CollectionStatus</td>
                                                <td>@item.Amount.ToString("0.####", CultureInfo.CurrentCulture)</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.DocumentNo) ? "-" : item.DocumentNo)</td>
                                                <td>@(item.DueDateUtc.HasValue ? item.DueDateUtc.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) : "-")</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.ReferenceNo) ? "-" : item.ReferenceNo)</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.Note) ? "-" : item.Note)</td>
                                                <td class="text-center">
                                                    <a asp-action="CollectionDetails" asp-route-id="@item.Id" class="btn btn-default btn-sm">@T("Admin.Common.View")</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="12" class="text-center">@T("Admin.Customers.DealerCollections.NoData")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
