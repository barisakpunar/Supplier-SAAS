@model DealerListModel
@{
    ViewBag.PageTitle = T("Admin.Customers.Dealers").Text;
    NopHtml.SetActiveMenuItemSystemName("Dealers");
}

<div class="content-header clearfix">
    <h1 class="float-left">@T("Admin.Customers.Dealers")</h1>
    <div class="float-right">
        <a asp-action="Collections" class="btn btn-default">
            <i class="fas fa-money-check-dollar"></i>
            @T("Admin.Customers.DealerCollections")
        </a>
        <a asp-action="Transactions" class="btn btn-default">
            <i class="fas fa-file-invoice-dollar"></i>
            @T("Admin.Customers.Dealers.Transactions")
        </a>
        @if (!Model.IsStoreOwner)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-square-plus"></i>
                @T("Admin.Customers.Dealers.AddNew")
            </a>
        }
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <form asp-action="List" asp-controller="Dealer" method="get">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchName" />
                                        </div>
                                        <div class="col-md-8">
                                            <input asp-for="SearchName" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                                @if (!Model.IsStoreOwner)
                                {
                                    <div class="col-md-6">
                                        <div class="form-group row">
                                            <div class="col-md-4">
                                                <nop-label asp-for="SearchStoreId" />
                                            </div>
                                            <div class="col-md-8">
                                                <select asp-for="SearchStoreId" asp-items="Model.AvailableStores" class="form-control"></select>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="row">
                                <div class="text-center col-12">
                                    <button type="submit" class="btn btn-primary btn-search">
                                        <i class="fas fa-magnifying-glass"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>@T("Admin.Customers.Dealers.Fields.Name")</th>
                                        <th>@T("Admin.Customers.Dealers.Fields.Store")</th>
                                        <th>@T("Admin.Customers.Dealers.Fields.Active")</th>
                                        <th>@T("Admin.Customers.Dealers.Fields.CustomerCount")</th>
                                        <th>@T("Admin.Customers.Dealers.Fields.PaymentMethods")</th>
                                        <th style="width: 100px;">@T("Admin.Common.Edit")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Dealers.Any())
                                    {
                                        foreach (var dealer in Model.Dealers)
                                        {
                                            <tr>
                                                <td>@dealer.Name</td>
                                                <td>@dealer.StoreName</td>
                                                <td>
                                                    @if (dealer.Active)
                                                    {
                                                        <span class="badge badge-success">@T("Admin.Common.Yes")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-danger">@T("Admin.Common.No")</span>
                                                    }
                                                </td>
                                                <td>@dealer.CustomerCount</td>
                                                <td>@dealer.PaymentMethodsSummary</td>
                                                <td class="text-center">
                                                    <a asp-action="Edit" asp-route-id="@dealer.Id" class="btn btn-default btn-sm">@T("Admin.Common.Edit")</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center">@T("Admin.Customers.Dealers.List.NoDealers")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
