@model DealerSegmentListModel
@{
    ViewBag.PageTitle = T("Admin.Customers.DealerSegments").Text;
    NopHtml.SetActiveMenuItemSystemName("DealerSegments");
}

<div class="content-header clearfix">
    <h1 class="float-left">@T("Admin.Customers.DealerSegments")</h1>
    <div class="float-right">
        <a asp-action="CreateSegment" class="btn btn-primary">
            <i class="fas fa-square-plus"></i>
            @T("Admin.Customers.DealerSegments.AddNew")
        </a>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <form asp-action="Segments" asp-controller="Dealer" method="get">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchName" />
                                        </div>
                                        <div class="col-md-8">
                                            <input asp-for="SearchName" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                                @if (!Model.IsStoreOwner)
                                {
                                    <div class="col-md-4">
                                        <div class="form-group row">
                                            <div class="col-md-4">
                                                <nop-label asp-for="SearchStoreId" />
                                            </div>
                                            <div class="col-md-8">
                                                <select asp-for="SearchStoreId" asp-items="Model.AvailableStores" class="form-control"></select>
                                            </div>
                                        </div>
                                    </div>
                                }
                                <div class="col-md-4">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchActive" />
                                        </div>
                                        <div class="col-md-8">
                                            <select asp-for="SearchActive" class="form-control">
                                                <option value="">@T("Admin.Common.All")</option>
                                                <option value="true">@T("Admin.Common.Yes")</option>
                                                <option value="false">@T("Admin.Common.No")</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="text-center col-12">
                                    <button type="submit" class="btn btn-primary btn-search">
                                        <i class="fas fa-magnifying-glass"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>@T("Admin.Customers.DealerSegments.Fields.Name")</th>
                                        <th>@T("Admin.Customers.DealerSegments.Fields.Code")</th>
                                        <th>@T("Admin.Customers.DealerSegments.Fields.Store")</th>
                                        <th>@T("Admin.Customers.DealerSegments.Fields.Active")</th>
                                        <th>@T("Admin.Customers.DealerSegments.Fields.DisplayOrder")</th>
                                        <th>@T("Admin.Customers.DealerSegments.Fields.DealerCount")</th>
                                        <th style="width: 100px;">@T("Admin.Common.Edit")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Segments.Any())
                                    {
                                        foreach (var segment in Model.Segments)
                                        {
                                            <tr>
                                                <td>@segment.Name</td>
                                                <td>@segment.Code</td>
                                                <td>@segment.StoreName</td>
                                                <td>
                                                    @if (segment.Active)
                                                    {
                                                        <span class="badge badge-success">@T("Admin.Common.Yes")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-danger">@T("Admin.Common.No")</span>
                                                    }
                                                </td>
                                                <td>@segment.DisplayOrder</td>
                                                <td>@segment.DealerCount</td>
                                                <td class="text-center">
                                                    <a asp-action="EditSegment" asp-route-id="@segment.Id" class="btn btn-default btn-sm">@T("Admin.Common.Edit")</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center">@T("Admin.Customers.DealerSegments.List.NoData")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
