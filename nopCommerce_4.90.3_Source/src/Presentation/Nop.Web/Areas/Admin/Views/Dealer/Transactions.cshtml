@using System.Globalization
@model DealerTransactionListModel
@{
    ViewBag.PageTitle = T("Admin.Customers.Dealers.Transactions").Text;
    NopHtml.SetActiveMenuItemSystemName("DealerTransactions");
}

<div class="content-header clearfix">
    <h1 class="float-left">@T("Admin.Customers.Dealers.Transactions")</h1>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <form asp-action="Transactions" asp-controller="Dealer" method="post">
                            <div class="row">
                                @if (!Model.IsStoreOwner)
                                {
                                    <div class="col-md-6">
                                        <div class="form-group row">
                                            <div class="col-md-4">
                                                <nop-label asp-for="SearchStoreId" />
                                            </div>
                                            <div class="col-md-8">
                                                <nop-select asp-for="SearchStoreId" asp-items="Model.AvailableStores" />
                                            </div>
                                        </div>
                                    </div>
                                }
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchDealerId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchDealerId" asp-items="Model.AvailableDealers" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchCreatedFromUtc" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="SearchCreatedFromUtc" asp-template="DateNullable" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchCreatedToUtc" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="SearchCreatedToUtc" asp-template="DateNullable" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="text-center col-12">
                                    <button type="submit" name="search-transactions" class="btn btn-primary btn-search">
                                        <i class="fas fa-magnifying-glass"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                    <button type="submit" name="exportcsv-all" class="btn btn-success">
                                        <i class="fas fa-download"></i>
                                        @T("Admin.Common.ExportToCsv")
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                @if (!Model.IsStatementMode)
                {
                    <div class="alert alert-info">
                        @T("Admin.Customers.Dealers.Transactions.StatementModeHint.Text")
                    </div>
                }

                <div class="card card-default">
                    <div class="card-header">
                        <h3 class="card-title">@T("Admin.Customers.Dealers.Transactions.Summary")</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @if (Model.IsStatementMode)
                            {
                                <div class="col-md-12 mb-2">
                                    <strong>@T("Admin.Customers.Dealers.Transactions.StatementDealer"):</strong> @Model.StatementDealerName
                                </div>
                            }
                            <div class="col-md-3">
                                <strong>@T("Admin.Customers.Dealers.Transactions.Summary.TotalDebit"):</strong> @Model.TotalDebit.ToString("0.####", CultureInfo.CurrentCulture)
                            </div>
                            <div class="col-md-3">
                                <strong>@T("Admin.Customers.Dealers.Transactions.Summary.TotalCredit"):</strong> @Model.TotalCredit.ToString("0.####", CultureInfo.CurrentCulture)
                            </div>
                            <div class="col-md-3">
                                <strong>@T("Admin.Customers.Dealers.Transactions.Summary.NetBalance"):</strong> @Model.NetBalance.ToString("0.####", CultureInfo.CurrentCulture)
                            </div>
                            @if (Model.IsStatementMode)
                            {
                                <div class="col-md-3">
                                    <strong>@T("Admin.Customers.Dealers.Transactions.Summary.OpeningBalance"):</strong> @Model.OpeningBalance.ToString("0.####", CultureInfo.CurrentCulture)
                                </div>
                                <div class="col-md-3">
                                    <strong>@T("Admin.Customers.Dealers.Transactions.Summary.ClosingBalance"):</strong> @Model.ClosingBalance.ToString("0.####", CultureInfo.CurrentCulture)
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 170px;">@T("Admin.Customers.Dealers.Transactions.Columns.CreatedOnUtc")</th>
                                        <th style="width: 220px;">@T("Admin.Customers.Dealers.Transactions.Columns.Dealer")</th>
                                        <th style="width: 160px;">@T("Admin.Customers.Dealers.Transactions.Columns.Store")</th>
                                        <th style="width: 210px;">@T("Admin.Customers.Dealers.Transactions.Columns.Type")</th>
                                        <th style="width: 120px;">@T("Admin.Customers.Dealers.Transactions.Columns.Debit")</th>
                                        <th style="width: 120px;">@T("Admin.Customers.Dealers.Transactions.Columns.Credit")</th>
                                        <th style="width: 140px;">@T("Admin.Customers.Dealers.Transactions.Columns.RunningBalance")</th>
                                        <th style="width: 90px;">@T("Admin.Customers.Dealers.Transactions.Columns.Order")</th>
                                        <th style="width: 100px;">@T("Admin.Customers.Dealers.Transactions.Columns.Customer")</th>
                                        <th>@T("Admin.Customers.Dealers.Transactions.Columns.Note")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Transactions.Any())
                                    {
                                        foreach (var transaction in Model.Transactions)
                                        {
                                            <tr>
                                                <td>@transaction.CreatedOnUtc.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)</td>
                                                <td>
                                                    @transaction.DealerName
                                                    <div>
                                                        <a asp-action="Edit" asp-controller="Dealer" asp-route-id="@transaction.DealerId">@T("Admin.Customers.Dealers.Transactions.OpenDealer")</a>
                                                    </div>
                                                </td>
                                                <td>@transaction.StoreName</td>
                                                <td>@transaction.TransactionType</td>
                                                <td>@(transaction.DebitAmount > 0 ? transaction.DebitAmount.ToString("0.####", CultureInfo.CurrentCulture) : "-")</td>
                                                <td>@(transaction.CreditAmount > 0 ? transaction.CreditAmount.ToString("0.####", CultureInfo.CurrentCulture) : "-")</td>
                                                <td>@(transaction.RunningBalance.HasValue ? transaction.RunningBalance.Value.ToString("0.####", CultureInfo.CurrentCulture) : "-")</td>
                                                <td>@(transaction.OrderId?.ToString() ?? "-")</td>
                                                <td>@(transaction.CustomerId?.ToString() ?? "-")</td>
                                                <td>@(string.IsNullOrWhiteSpace(transaction.Note) ? "-" : transaction.Note)</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="10" class="text-center">@T("Admin.Customers.Dealers.Transactions.NoData")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
