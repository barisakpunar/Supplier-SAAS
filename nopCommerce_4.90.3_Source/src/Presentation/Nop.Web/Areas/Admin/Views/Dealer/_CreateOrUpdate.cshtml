@using System.Globalization
@model DealerModel

<div asp-validation-summary="All"></div>
<input asp-for="Id" type="hidden" />

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            @if (Model.IsStoreOwner)
            {
                <div class="alert alert-info">
                    You are editing your assigned dealer scope. Store is fixed to your current store.
                </div>
            }

            <div class="card card-default">
                <div class="card-header">
                    <h3 class="card-title">Dealer information</h3>
                </div>
                <div class="card-body">
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="Name" class="col-form-label">Name</label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="StoreId" class="col-form-label">Store</label>
                        </div>
                        <div class="col-md-9">
                            @if (Model.IsStoreOwner)
                            {
                                <input type="text" class="form-control" value="@Model.StoreName" disabled />
                                <input asp-for="StoreId" type="hidden" />
                            }
                            else
                            {
                                <select asp-for="StoreId" asp-items="Model.AvailableStores" class="form-control"></select>
                            }
                            <span asp-validation-for="StoreId"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="Active" class="col-form-label">Active</label>
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="Active" />
                            <span asp-validation-for="Active"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-default">
                <div class="card-header">
                    <h3 class="card-title">Open account</h3>
                </div>
                <div class="card-body">
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="OpenAccountEnabled" class="col-form-label">Enable open account</label>
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="OpenAccountEnabled" />
                            <span asp-validation-for="OpenAccountEnabled"></span>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="CreditLimit" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="CreditLimit" />
                            <span asp-validation-for="CreditLimit"></span>
                            <small class="form-text text-muted">Used for open account validation (MVP).</small>
                        </div>
                    </div>
                    @if (Model.Id > 0)
                    {
                        <div class="form-group row">
                            <div class="col-md-3">
                                <label class="col-form-label">Current debt</label>
                            </div>
                            <div class="col-md-9">
                                <input type="text" class="form-control" value="@Model.CurrentDebt.ToString("0.####", CultureInfo.CurrentCulture)" readonly />
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-3">
                                <label class="col-form-label">Available credit</label>
                            </div>
                            <div class="col-md-9">
                                <input type="text" class="form-control" value="@Model.AvailableCredit.ToString("0.####", CultureInfo.CurrentCulture)" readonly />
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card card-default">
                <div class="card-header">
                    <h3 class="card-title">Dealer customers</h3>
                </div>
                <div class="card-body">
                    @{
                        var displayedCustomers = Model.Id > 0
                            ? Model.AvailableCustomers
                                .Where(item => int.TryParse(item.Value, out var id) && Model.SelectedCustomerIds.Contains(id))
                                .OrderBy(item => item.Text)
                                .ToList()
                            : Model.AvailableCustomers
                                .OrderBy(item => item.Text)
                                .ToList();
                    }

                    <p class="text-muted">
                        Customer mapping is managed from customer edit screen.
                        @(Model.Id > 0 ? "Only mapped customers are shown." : "Customers in selected store are listed for reference.")
                    </p>

                    @if (displayedCustomers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>Customer</th>
                                        <th style="width: 120px;">Edit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var customerItem in displayedCustomers)
                                    {
                                        <tr>
                                            <td>@customerItem.Text</td>
                                            <td class="text-center">
                                                <a class="btn btn-default btn-sm" href="@Url.Action("Edit", "Customer", new { id = customerItem.Value })">Open</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">No customers to display.</div>
                    }
                </div>
            </div>

            <div class="card card-default">
                <div class="card-header">
                    <h3 class="card-title">Allowed payment methods</h3>
                </div>
                <div class="card-body">
                    <p class="text-muted">Leave empty to allow all active payment methods for this dealer.</p>
                    @if (Model.AvailablePaymentMethods.Any())
                    {
                        <div class="row">
                            @for (var index = 0; index < Model.AvailablePaymentMethods.Count; index++)
                            {
                                var paymentMethod = Model.AvailablePaymentMethods[index];
                                var paymentMethodId = $"payment-method-{index}";
                                var isChecked = Model.SelectedPaymentMethodSystemNames
                                    .Any(systemName => string.Equals(systemName, paymentMethod.Value, StringComparison.InvariantCultureIgnoreCase));

                                <div class="col-md-6 mb-2">
                                    <div class="form-check">
                                        @if (isChecked)
                                        {
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="@paymentMethodId"
                                                   name="SelectedPaymentMethodSystemNames"
                                                   value="@paymentMethod.Value"
                                                   checked="checked" />
                                        }
                                        else
                                        {
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="@paymentMethodId"
                                                   name="SelectedPaymentMethodSystemNames"
                                                   value="@paymentMethod.Value" />
                                        }
                                        <label class="form-check-label" for="@paymentMethodId">@paymentMethod.Text</label>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">No active payment methods found for selected store.</div>
                    }
                </div>
            </div>

            @if (Model.Id > 0)
            {
                <div class="card card-default">
                    <div class="card-header">
                        <h3 class="card-title">Manual transaction entry</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Use this section to add manual collection or manual debt adjustments.</p>
                        <div class="form-group row">
                            <div class="col-md-3">
                                <label asp-for="ManualTransactionTypeId" class="col-form-label">Transaction type</label>
                            </div>
                            <div class="col-md-9">
                                <select asp-for="ManualTransactionTypeId" asp-items="Model.AvailableManualTransactionTypes" class="form-control"></select>
                                <span asp-validation-for="ManualTransactionTypeId"></span>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-label asp-for="ManualTransactionAmount" />
                            </div>
                            <div class="col-md-9">
                                <nop-editor asp-for="ManualTransactionAmount" />
                                <span asp-validation-for="ManualTransactionAmount"></span>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-3">
                                <label asp-for="ManualTransactionNote" class="col-form-label">Note</label>
                            </div>
                            <div class="col-md-9">
                                <textarea asp-for="ManualTransactionNote" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="ManualTransactionNote"></span>
                            </div>
                        </div>
                        <div class="form-group row mb-0">
                            <div class="col-md-9 offset-md-3">
                                <button type="submit" name="add-transaction" value="add-transaction" class="btn btn-secondary">
                                    Add transaction
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-header">
                        <h3 class="card-title">Dealer transactions</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Shows latest @Model.Transactions.Count transaction(s). Full ledger actions will be added in the next iteration.</p>

                        @if (Model.Transactions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 180px;">Created (UTC)</th>
                                            <th style="width: 210px;">Type</th>
                                            <th style="width: 90px;">Direction</th>
                                            <th style="width: 120px;">Amount</th>
                                            <th style="width: 90px;">Order</th>
                                            <th style="width: 100px;">Customer</th>
                                            <th>Note</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var transaction in Model.Transactions)
                                        {
                                            <tr>
                                                <td>@transaction.CreatedOnUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                                <td>@transaction.TransactionType</td>
                                                <td>@transaction.Direction</td>
                                                <td>@transaction.Amount.ToString("0.####", CultureInfo.CurrentCulture)</td>
                                                <td>@(transaction.OrderId?.ToString() ?? "-")</td>
                                                <td>@(transaction.CustomerId?.ToString() ?? "-")</td>
                                                <td>@(string.IsNullOrWhiteSpace(transaction.Note) ? "-" : transaction.Note)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0">No transactions to display.</div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<script>
    if (window.jQuery && $.validator && $.validator.methods) {
        $.validator.methods.number = function (value, element) {
            if (this.optional(element))
                return true;

            value = (value || '').replace(/\s/g, '');
            return /^-?(?:\d+|\d{1,3}(?:[.,]\d{3})*)(?:[.,]\d+)?$/.test(value);
        };
    }
</script>
