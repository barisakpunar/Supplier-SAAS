@model DealerModel

<div asp-validation-summary="All"></div>
<input asp-for="Id" type="hidden" />

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            @if (Model.IsStoreOwner)
            {
                <div class="alert alert-info">
                    You are editing your assigned dealer scope. Store is fixed to your current store.
                </div>
            }

            <div class="card card-default">
                <div class="card-header">
                    <h3 class="card-title">Dealer information</h3>
                </div>
                <div class="card-body">
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="Name" class="col-form-label">Name</label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="StoreId" class="col-form-label">Store</label>
                        </div>
                        <div class="col-md-9">
                            @if (Model.IsStoreOwner)
                            {
                                <input type="text" class="form-control" value="@Model.StoreName" disabled />
                                <input asp-for="StoreId" type="hidden" />
                            }
                            else
                            {
                                <select asp-for="StoreId" asp-items="Model.AvailableStores" class="form-control"></select>
                            }
                            <span asp-validation-for="StoreId"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="Active" class="col-form-label">Active</label>
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="Active" />
                            <span asp-validation-for="Active"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-default">
                <div class="card-header">
                    <h3 class="card-title">Dealer customers</h3>
                </div>
                <div class="card-body">
                    @if (Model.Id <= 0)
                    {
                        <p class="text-muted">Only customers of selected store are listed.</p>
                        <nop-select asp-for="SelectedCustomerIds" asp-items="Model.AvailableCustomers" asp-multiple="true" />
                    }
                    else
                    {
                        var selectedCustomers = Model.AvailableCustomers
                            .Where(item => int.TryParse(item.Value, out var id) && Model.SelectedCustomerIds.Contains(id))
                            .OrderBy(item => item.Text)
                            .ToList();

                        <p class="text-muted">Customer mapping is readonly on edit screen.</p>

                        @if (selectedCustomers.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th>Customer</th>
                                            <th style="width: 120px;">Edit</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var customer in selectedCustomers)
                                        {
                                            <tr>
                                                <td>@customer.Text</td>
                                                <td class="text-center">
                                                    <a class="btn btn-default btn-sm" href="@Url.Action("Edit", "Customer", new { id = customer.Value })">Open</a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0">No mapped customers.</div>
                        }
                    }
                </div>
            </div>

            <div class="card card-default">
                <div class="card-header">
                    <h3 class="card-title">Allowed payment methods</h3>
                </div>
                <div class="card-body">
                    <p class="text-muted">Leave empty to allow all active payment methods for this dealer.</p>
                    <nop-select asp-for="SelectedPaymentMethodSystemNames" asp-items="Model.AvailablePaymentMethods" asp-multiple="true" />
                </div>
            </div>
        </div>
    </div>
</section>
